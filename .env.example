# Flux Panel Plus deployment settings
COMPOSE_PROJECT_NAME=flux-panel-plus

# Image tag published by GitHub Actions. Use "latest" for the newest stable build.
FLUX_VERSION=latest

# MySQL credentials. Replace every CHANGE_ME value before deployment.
DB_NAME=flux_db
DB_USER=flux_user
DB_PASSWORD=CHANGE_ME_WITH_A_LONG_RANDOM_VALUE

# JWT signing secret. Changing it logs out all existing panel sessions.
JWT_SECRET=CHANGE_ME_WITH_ANOTHER_LONG_RANDOM_VALUE

# Panel listen address and port.
PANEL_LISTEN=0.0.0.0
PANEL_PORT=6366

# Set to true only after Docker IPv6 has been configured on the host.
ENABLE_IPV6=false

# Optional comma-separated CORS allowlist. Empty keeps the application default.
ALLOWED_ORIGINS=

# Container timezone.
TZ=Asia/Shanghai
